# Browser local dev can leave this empty and call the same-origin Express API.
# iOS/Capacitor builds must set this in .env.capacitor to your deployed HTTPS domain.
# Example: VITE_API_BASE_URL=https://interview.danzaii.cn
VITE_API_BASE_URL=""

# Server-side only. Configure these in Vercel Project Settings, never with VITE_.
# Provider defaults to volcengine because the App Store-facing product should present
# this as MianLeMe's own hosted AI service, not user-selected third-party BYOK.
MIANLEME_AI_PROVIDER="volcengine"
MIANLEME_AI_API_KEY="MY_SERVER_SIDE_AI_KEY"
MIANLEME_AI_MODEL="MY_MODEL_OR_ENDPOINT_ID"
MIANLEME_AI_API_BASE="https://ark.cn-beijing.volces.com/api/v3"

# Compatibility env names are still accepted by the server if already configured:
# GEMINI_API_KEY / GOOGLE_API_KEY
# VOLCENGINE_API_KEY / ARK_API_KEY
# OPENAI_API_KEY
# ANTHROPIC_API_KEY

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
